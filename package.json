{
  "name": "constellation-project-creator",
  "displayName": "Constellation Project Creator",
  "description": "Creates complete projects with ready-to-use structure for multiple frameworks and architectures (MVC, DDD, Clean, Hexagonal)",
  "version": "0.0.2",
  "publisher": "SidAlbertaodasmassa",
  "icon": "icon.ico",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidneiAJr/constellation-project-creator"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "project-generator",
    "mvc",
    "ddd",
    "clean-architecture",
    "hexagonal",
    "nodejs",
    "typescript",
    "spring-boot",
    "php",
    "csharp"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "constellation.createProject",
        "title": "🏗️ Constellation: Create New Project (Select Architecture)"
      },
      {
        "command": "constellation.createMVCProject",
        "title": "🏗️ Constellation: Create MVC Project"
      },
      {
        "command": "constellation.createDDDProject",
        "title": "🎯 Constellation: Create DDD Project"
      },
      {
        "command": "constellation.createCleanProject",
        "title": "✨ Constellation: Create Clean Architecture Project"
      },
      {
        "command": "constellation.createHexagonalProject",
        "title": "🔷 Constellation: Create Hexagonal Project"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "constellation.createProject",
          "group": "1_constellation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}